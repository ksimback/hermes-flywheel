# Optional NVIDIA/NIM API key for Nemotron model access
NVIDIA_API_KEY=replace_with_nvidia_key

# Optional OpenAI API key for fallback model provider
OPENAI_API_KEY=replace_with_openai_key

# Optional Slack gateway tokens for running Flywheel as a tagged GTM employee
SLACK_BOT_TOKEN=replace_with_slack_bot_token
SLACK_APP_TOKEN=replace_with_slack_app_token

# Optional Stripe keys for payment/spend functionality (test mode recommended)
STRIPE_API_KEY=replace_with_stripe_test_key
STRIPE_WEBHOOK_SECRET=replace_with_stripe_webhook_secret

# Optional web-search API key for headless research runs
SERPER_API_KEY=replace_with_serper_key
